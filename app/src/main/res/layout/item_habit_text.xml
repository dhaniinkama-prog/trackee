<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_btn_pink"
    android:backgroundTint="#9381C4"
    android:paddingHorizontal="16dp">

    <CheckBox
        android:id="@+id/cbHabitDone"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:buttonTint="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtHabitName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="12dp"
        android:text="Membaca Buku"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/txtHabitStatus"
        app:layout_constraintEnd_toStartOf="@+id/txtHabitProgress"
        app:layout_constraintStart_toEndOf="@+id/cbHabitDone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/txtHabitStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="★ New"
        android:textColor="#E6DFF7"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/txtHabitName"
        app:layout_constraintTop_toBottomOf="@+id/txtHabitName" />

    <TextView
        android:id="@+id/txtHabitProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/200\npages"
        android:textAlignment="center"
        android:textColor="#FFE4E1"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>