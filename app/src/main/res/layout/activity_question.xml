<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <!-- Judul Pertanyaan -->

    <!-- Maskot -->

    <!-- Tombol 1 -->

    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="359dp"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="34dp"
        android:layout_marginTop="163dp"
        android:layout_marginEnd="18dp"
        android:fontFamily="@font/poppins_semibold"
        android:text="Do you procrastinate?"
        android:textColor="#000000"
        android:textSize="40sp" />

    <Button
        android:id="@+id/buttonskip"
        android:layout_width="287dp"
        android:layout_height="50dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="88dp"
        android:text="Not ready to answer"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:backgroundTint="#8187D6" />

    <Button
        android:id="@+id/buttonno"
        android:layout_width="287dp"
        android:layout_height="50dp"
        android:layout_above="@+id/buttonskip"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="20dp"
        android:text="No, I easily finish the tasks at hand"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:backgroundTint="#A7AAE1" />

    <Button
        android:id="@+id/buttonyes"
        android:layout_width="287dp"
        android:layout_height="50dp"
        android:layout_above="@+id/buttonno"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="20dp"
        android:text="Yes and I'm ready to change that"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:backgroundTint="#C2C9FF" />

    <ImageView
        android:id="@+id/imgMascot"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_above="@+id/buttonyes"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="252dp"
        android:layout_marginTop="180dp"
        android:layout_marginEnd="9dp"
        android:layout_marginBottom="-43dp"
        android:scaleType="fitCenter"
        android:src="@drawable/mascot" />


    <!-- Tombol 2 -->

    <!-- Tombol 3 -->

</RelativeLayout>
